# =============================================================================
# .env.example – Environment variable template
#
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in values   (see comments for where to get each one)
#   3. NEVER commit .env to git  (.gitignore already excludes it)
#
# Docker Compose reads .env automatically from the same directory.
# =============================================================================

# ─── GitHub ──────────────────────────────────────────────────────────────────

# Personal Access Token (classic)
# Generate at: https://github.com/settings/tokens
# Required scopes: repo, admin:repo_hook
GITHUB_TOKEN=ghp_CHANGEME

# Username that owns the token (used for basic auth in casc.yaml)
GITHUB_USERNAME=your-github-username

# Secret string shared between GitHub webhook and Jenkins
# Generate a strong random value, e.g.:
#   openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=CHANGEME_generate_with_openssl_rand_hex_32

# ─── SonarQube ───────────────────────────────────────────────────────────────

# Default admin password shipped by SonarQube – do not change this value,
# it is the factory default used on the very first login attempt.
SONAR_DEFAULT_PASSWORD=admin

# New admin password set by sonar-setup.sh on first run.
# Must be at least 12 characters and contain uppercase, lowercase, and a digit.
SONAR_NEW_PASSWORD=CHANGEME_strong_password_12chars

# SonarQube analysis token
# Generate at: http://localhost:9000 → My Account → Security → Generate Token
# Update this AFTER first SonarQube login (run scripts/sonar-setup.sh first)
SONAR_TOKEN=squ_CHANGEME

# ─── Jenkins ─────────────────────────────────────────────────────────────────

# Jenkins admin username (matches the id in casc.yaml – default: admin)
JENKINS_ADMIN_USERNAME=admin

# Jenkins admin password (default is 'admin' – change for any shared environment)
JENKINS_ADMIN_PASSWORD=admin

# Jenkins base URL reachable from the host machine
JENKINS_URL=http://localhost:8080

# ─── ngrok ───────────────────────────────────────────────────────────────────

# ngrok authtoken – required to start the tunnel
# Sign up free at https://ngrok.com → Dashboard → Your Authtoken
NGROK_TOKEN=CHANGEME_your_ngrok_authtoken
